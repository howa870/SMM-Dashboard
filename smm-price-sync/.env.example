# ──────────────────────────────────────────────
# SMM Price Sync — Environment Variables
# ──────────────────────────────────────────────

# مفتاح API الخاص بك من مزود الخدمة
API_KEY=your_api_key_here

# رابط API المزود (اتركه كما هو لـ Followiz)
API_URL=https://followiz.com/api/v2

# ──────────────────────────────────────────────
# Telegram Bot Settings
# ──────────────────────────────────────────────

# توكن البوت من @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# معرف القناة أو المجموعة أو الشخص
# للحصول عليه: أرسل رسالة للبوت ثم افتح
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=-1001234567890

# ──────────────────────────────────────────────
# Pricing Settings
# ──────────────────────────────────────────────

# نسبة الربح (1.5 = 50% ربح)
MARKUP=1.5

# الحد الأدنى للسعر (IQD) — لتجنب أسعار أقل من الحد
MIN_SELL_PRICE=0.01
