{
  "buildCommand": "pnpm --filter @workspace/smm-panel run build",
  "outputDirectory": "artifacts/smm-panel/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "build": {
    "env": {
      "BASE_PATH": "/",
      "NODE_ENV": "production",
      "VITE_API_URL": ""
    }
  },
  "functions": {
    "api/telegram.js":      { "maxDuration": 30 },
    "api/payment.js":       { "maxDuration": 15 },
    "api/order.js":         { "maxDuration": 15 },
    "api/sync-orders.js":   { "maxDuration": 60 },
    "api/smm/services.js":  { "maxDuration": 15 },
    "api/auth/jwt-sync.js": { "maxDuration": 10 },
    "api/auth/login.js":    { "maxDuration": 10 },
    "api/**/*.js":          { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/google6c97654db5995a94.html", "destination": "/api/google6c97654db5995a94" },
    { "source": "/((?!api(?:/|$)).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,apikey,x-client-info" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
